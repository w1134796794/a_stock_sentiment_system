# Local environments and secrets
.venv/
venv/
.env
.env.local

# Python caches and test artifacts
__pycache__/
*.py[cod]
.pytest_cache/
.coverage
htmlcov/

# Logs and local caches
/logs/
*.log
/data/
/output/

# Runtime data generated by web pages, daily jobs, realtime tasks and backtests
/webdata/backtest_trade_plans/
/webdata/etl_quality/
/webdata/logs/
/webdata/output/
/webdata/realtime/
/webdata/screening/
/webdata/snapshots/
/webdata/warehouse/
/webdata/config_overrides.json

# Mutable runtime databases must stay outside Git. The application initializes
# app/auth schemas when the files are absent.
/webdata/*.sqlite
/webdata/*.sqlite-*
/webdata/*.sqlite.*
/webdata/*.duckdb
/webdata/*.duckdb-*
/webdata/*.duckdb.*

# Optional sanitized, schema-only databases may be shipped with a release.
!/webdata/bootstrap/
!/webdata/bootstrap/*.sqlite
!/webdata/README.md

# OS and editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
